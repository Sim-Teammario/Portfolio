{% extends 'base.twig' %}
{% block title %}Formation{% endblock %}
{% block content %}
    <h1>Formation</h1>

    <section class="content-card">
        <h2>Titre RNCP niveau 6 — Administrateur d’infrastructures sécurisées</h2>
        <p>Formation axée sur l’administration et la sécurisation d’infrastructures systèmes.</p>
        <p>Elle couvre la gestion des environnements serveurs, la supervision, la mise en place de solutions de sécurité et la résolution d’incidents.</p>
        <p>
            <a class="btn" href="{{ rncp_url }}" target="_blank" rel="noopener noreferrer">Consulter la fiche RNCP</a>
        </p>
    </section>

    <section class="content-card">
        <h2>Préparation d’un diplôme de niveau bac +5 dans le domaine des infrastructures et de la cybersécurité.</h2>
        <p>Objectif : approfondir la gestion des systèmes d’information, la cybersécurité et le pilotage d’infrastructures à plus grande échelle.</p>
    </section>
{% endblock %}